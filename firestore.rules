rules_version = '2';

// Zuupah Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    /// Check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Check if the authenticated user owns this document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Books (read-only for all authenticated users) ─────────────────────────
    match /books/{bookId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin SDK can write books
    }

    // ── Categories (public read) ──────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Firmware Versions (public read) ──────────────────────────────────────
    match /firmwareVersions/{versionId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Users (own data only) ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }
  }
}
