{
  "name": "zuupah",
  "version": "0.1.0",
  "description": "Interactive learning pen app - Play. Learn. Explore.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:rn": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace Zuupah.xcworkspace -scheme Zuupah -configuration Release"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "expo": "~50.0.0",
    "expo-dev-client": "~3.3.0",
    "expo-status-bar": "~1.11.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/stack": "^6.3.20",
    "react-native-screens": "^3.26.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-vector-icons": "^10.0.0",
    "@react-native-firebase/app": "^18.6.0",
    "@react-native-firebase/auth": "^18.6.0",
    "@react-native-firebase/firestore": "^18.6.0",
    "@react-native-firebase/storage": "^18.6.0",
    "react-native-ble-plx": "^3.2.0",
    "react-native-permissions": "^3.10.0",
    "react-native-fs": "^2.20.0",
    "zustand": "^4.4.0",
    "axios": "^1.6.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.3.0",
    "@react-native/metro-config": "^0.73.0",
    "babel-jest": "^29.7.0",
    "metro": "^0.80.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@testing-library/react-native": "^12.3.0",
    "react-test-renderer": "18.2.0",
    "@types/react-test-renderer": "^18.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
